COMPOSE_PROJECT_NAME=pricepilot-ai
TZ=Asia/Shanghai

# Optional Binance Spot Testnet credentials for scripts/price_action_agent.py.
# Never use production Binance keys for assignment simulation.
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
BINANCE_TESTNET_BASE_URL=https://testnet.binance.vision

# Optional OpenAI-compatible model advisor. If unset, the deterministic
# heuristic advisor is used.
PRICEPILOT_LLM_BASE_URL=
PRICEPILOT_LLM_API_KEY=
PRICEPILOT_LLM_MODEL=gpt-4.1-mini
